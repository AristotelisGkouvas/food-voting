[Unit]
Description=Food Voting Web Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=iq_dj
WorkingDirectory=/home/iq_dj/Documents/food-voting
ExecStart=/usr/bin/python3 server.py
Restart=on-failure
RestartSec=5
Environment=PORT=8000
Environment=HOST=0.0.0.0
Environment=SESSION_TIMEOUT_SECONDS=21600

[Install]
WantedBy=multi-user.target
